---
import BaseLayout from "../layouts/BaseLayout.astro";
import "./index.css";
---

<BaseLayout title="Home — Eduardo OS">
  <section class="hero">
    <h1>Zero Trust Microservices Platform</h1>
    <p>
      Astro + React frontend, Rust/Axum API gateway, and isolated Docker
      microservices with distributed flight tracing.
    </p>
    <div class="hero__actions">
      <a class="hero__button" href="/auth/register">Get started</a>
      <a class="hero__link" href="/auth/login">Sign in</a>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import { APP_ROUTES } from "../config/routes";
import "./index.css";
---

<BaseLayout title="Eduardo Osteicoechea">
  <div class="page-shell hero">
    <h1>Zero Trust Microservices Platform</h1>
    <p class="page-lead">
      Astro + React frontend, Rust/Axum API gateway, and isolated Docker
      microservices with distributed flight tracing.
    </p>
    <div class="hero__actions">
      <a class="btn btn--primary" href={APP_ROUTES.register}>Get started</a>
      <a class="btn" href={APP_ROUTES.login}>Sign in</a>
      <a class="btn" href={APP_ROUTES.logger}>Logger</a>
      <a class="btn" href={APP_ROUTES.tester}>Tester</a>
      <a class="btn" href={APP_ROUTES.pamphlet}>Pamphlet</a>
    </div>
  </div>
</BaseLayout>

---
/**
 * BaseLayout.astro — Root HTML shell (Eduardo OS chrome, PWA hooks, global audio player).
 */
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";
import "./BaseLayout.css";
import PageBackground from "../components/PageBackground/PageBackground.astro";
import GlobalPlayer from "../components/GlobalPlayer/GlobalPlayer";
import { isHomePath } from "../config/homeLayout";
import { Header } from "../components/Header/Header";

interface Props {
  title?: string;
  activityBarMode?: "default" | "article" | "editor";
}

const { title = "Eduardo Osteicoechea", activityBarMode = "default" } =
  Astro.props;

const pathname = Astro.url.pathname;
const pageHome = isHomePath(pathname);
const pageEditor = activityBarMode === "editor";
---

<!doctype html>
<html lang="en" class:list={{ "page-home": pageHome }}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="theme-color" content="#000000" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <ClientRouter />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,100..900;1,100..900&family=Raleway:ital,wght@0,100..900;1,100..900&family=Roboto:ital,wght@0,100..900;1,100..900&display=swap"
      rel="stylesheet"
    />

    <meta
      name="description"
      content="Licensed Architect & Software Developer focusing on full-stack AEC solutions, cloud applications, AI integration, BIM collaboration, and problem solving."
    />
    <link rel="icon" href="/media/favicon.ico" sizes="any" />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href="/media/favicon-32x32.png"
    />
    <link rel="icon" href="/favicon-48.png" sizes="48x48" type="image/png" />
    <link rel="icon" href="/favicon-96.png" sizes="96x96" type="image/png" />
    <link rel="icon" href="/favicon-192.png" sizes="192x192" type="image/png" />
    <link rel="apple-touch-icon" href="/favicon-180.png" sizes="180x180" />
    <link
      rel="shortcut icon"
      href="/favicon-32.png"
      sizes="32x32"
      type="image/png"
    />
    <meta
      name="google-site-verification"
      content="RQdklgFawBo75p5tN7wranunENDjUu27gol9MENm-SM"
    />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body
    class:list={{
      "page-editor": pageEditor,
      "has-page-background": true,
      "has-global-player": true,
    }}
  >
    <PageBackground />
    <Header client:load pathname={pathname} />
    <div transition:persist="audio-player">
      <GlobalPlayer client:load />
    </div>
    <main>
      <slot />
    </main>

    <div id="pwa-toast" role="status" aria-live="polite">
      <span>A new version of Eduardo OS is ready.</span>
      <button type="button" id="pwa-refresh">Refresh</button>
    </div>

    <script>
      /**
       * Service worker lifecycle — prompt the user via #pwa-toast when an update is waiting.
       * registerType is "prompt" in astro.config.mjs; updateSW(true) activates the worker.
       */
      import { registerSW } from "virtual:pwa-register";

      const updateSW = registerSW({
        onNeedRefresh() {
          document.getElementById("pwa-toast")?.classList.add("is-visible");
        },
        onOfflineReady() {
          /* Static shell precache completed; audio blobs use IndexedDB separately. */
        },
      });

      document.getElementById("pwa-refresh")?.addEventListener("click", () => {
        void updateSW(true);
      });
    </script>
  </body>
</html>

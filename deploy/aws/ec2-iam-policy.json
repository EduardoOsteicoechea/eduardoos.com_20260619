{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "S3MediaBucket",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket",
        "s3:GetBucketLocation",
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:AbortMultipartUpload",
        "s3:ListBucketMultipartUploads",
        "s3:ListMultipartUploadParts"
      ],
      "Resource": [
        "arn:aws:s3:::eduardoos20260607",
        "arn:aws:s3:::eduardoos20260607/*"
      ]
    },
    {
      "Sid": "DynamoDBApplicationTables",
      "Effect": "Allow",
      "Action": [
        "dynamodb:DescribeTable",
        "dynamodb:GetItem",
        "dynamodb:PutItem",
        "dynamodb:UpdateItem",
        "dynamodb:DeleteItem",
        "dynamodb:Query",
        "dynamodb:Scan",
        "dynamodb:BatchGetItem",
        "dynamodb:BatchWriteItem",
        "dynamodb:ConditionCheckItem"
      ],
      "Resource": [
        "arn:aws:dynamodb:us-east-1:241533144630:table/eduardoos_catalog",
        "arn:aws:dynamodb:us-east-1:241533144630:table/eduardoos_catalog/index/*",
        "arn:aws:dynamodb:us-east-1:241533144630:table/eduardoos_posts",
        "arn:aws:dynamodb:us-east-1:241533144630:table/eduardoos_posts/index/*",
        "arn:aws:dynamodb:us-east-1:241533144630:table/eduardoos_refresh_tokens",
        "arn:aws:dynamodb:us-east-1:241533144630:table/eduardoos_refresh_tokens/index/*",
        "arn:aws:dynamodb:us-east-1:241533144630:table/eduardoos_users",
        "arn:aws:dynamodb:us-east-1:241533144630:table/eduardoos_users/index/*"
      ]
    }
  ]
}
